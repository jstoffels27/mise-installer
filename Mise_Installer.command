#!/bin/bash
# Mise Installer — generated 2026-03-11
# Double-click this file in Finder to install.

_MB_B64=""
_GUI_B64=""
_TPL_B64=""
_HAS_TPL=true

# ── Helpers ───────────────────────────────────────────────────────────────────
BOLD="\033[1m"; DIM="\033[2m"; GREEN="\033[32m"
YELLOW="\033[33m"; RED="\033[31m"; RESET="\033[0m"

ok()    { echo -e "  ${GREEN}✓${RESET}  $*"; }
warn()  { echo -e "  ${YELLOW}⚠${RESET}  $*"; }
bad()   { echo -e "  ${RED}✗${RESET}  $*"; }
step()  { echo -e "  ${DIM}→${RESET}  $*"; }
sep()   { echo "  ──────────────────────────────────────────────"; }
pause() { echo ""; read -rp "  Press Enter to $1… " _; }

ISSUES=0
clear

# Bring Terminal window to front
osascript -e 'tell application "Terminal" to activate' 2>/dev/null || true

echo ""
echo -e "  ${BOLD}■  Mise  —  Installer${RESET}"
echo -e "  ${DIM}Square for Restaurants${RESET}"
sep
echo ""
echo "  Checking your machine…"
echo ""

# ── 1. Python 3 (fatal if missing) ───────────────────────────────────────────
if command -v python3 &>/dev/null; then
    ok "Python 3  ($(python3 --version 2>&1 | awk '{print $2}'))"
else
    bad "Python 3 not found"
    echo ""
    echo "  Python 3 is required. Install it by running:"
    echo ""
    echo "      xcode-select --install"
    echo ""
    echo "  Then double-click this installer again."
    pause "exit"; exit 1
fi

# ── 2. openpyxl (auto-install) ────────────────────────────────────────────────
if python3 -c "import openpyxl" 2>/dev/null; then
    ok "openpyxl already installed"
else
    step "Installing openpyxl…"
    if pip3 install openpyxl --quiet 2>/dev/null; then
        ok "openpyxl installed"
    else
        warn "Could not auto-install openpyxl"
        echo "      Please run this yourself:  pip3 install openpyxl"
        ISSUES=$((ISSUES + 1))
    fi
fi

# ── 3. Goose CLI (prompt if missing — cannot auto-install) ────────────────────
if command -v goose &>/dev/null; then
    ok "Goose CLI  ($(which goose))"
else
    warn "Goose CLI not found"
    echo ""
    echo -e "  ${BOLD}Action required before using Mise:${RESET}"
    echo "  This tool runs AI via Goose + your Databricks credentials."
    echo "  Ask your team lead how to set up Goose on your machine."
    echo ""
    ISSUES=$((ISSUES + 1))
fi

echo ""
sep
echo ""
echo "  Installing files…"
echo ""

# ── 4. Write scripts via Python (decodes embedded base64) ─────────────────────
mkdir -p "$HOME/bin"

_MB_DATA="$_MB_B64" _GUI_DATA="$_GUI_B64" python3 - << 'PYEOF'
import base64, os, stat

files = [
    (os.path.expanduser("~/bin/menu_build"),     "_MB_DATA"),
    (os.path.expanduser("~/bin/menu_build_gui"), "_GUI_DATA"),
]
for path, key in files:
    with open(path, "wb") as fh:
        fh.write(base64.b64decode(os.environ[key]))
    os.chmod(path, stat.S_IRWXU | stat.S_IRGRP | stat.S_IXGRP | stat.S_IROTH | stat.S_IXOTH)

print("  \033[32m✓\033[0m  Scripts installed to ~/bin/")
PYEOF

# ── 5. Catalogue template ─────────────────────────────────────────────────────
TPL_DEST="$HOME/Documents/claude_blank_menu_import_template.xlsx"

if [[ "$_HAS_TPL" == "true" ]]; then
    if [[ -f "$TPL_DEST" ]]; then
        ok "Catalogue template already in ~/Documents/"
    else
        _TPL_DATA="$_TPL_B64" python3 - << 'PYEOF'
import base64, os
dest = os.path.expanduser("~/Documents/claude_blank_menu_import_template.xlsx")
os.makedirs(os.path.dirname(dest), exist_ok=True)
with open(dest, "wb") as fh:
    fh.write(base64.b64decode(os.environ["_TPL_DATA"]))
print("  \033[32m✓\033[0m  Catalogue template installed to ~/Documents/")
PYEOF
    fi
else
    warn "Template not bundled — upload it manually in the GUI when prompted"
    ISSUES=$((ISSUES + 1))
fi

# ── 6. PATH ───────────────────────────────────────────────────────────────────
RC="$HOME/.zshrc"
[[ -n "$BASH_VERSION" ]] && RC="$HOME/.bash_profile"

if printf '%s\n' "${PATH//:/$'\n'}" | grep -qx "$HOME/bin"; then
    ok "~/bin already in PATH"
else
    echo 'export PATH="$HOME/bin:$PATH"' >> "$RC"
    ok "Added ~/bin to PATH in $(basename $RC)"
    echo "      Open a new terminal window after install for this to take effect."
fi

# ── 7. Create shortcut .app ───────────────────────────────────────────────────
echo ""
sep
echo ""

if [[ $ISSUES -eq 0 ]]; then
    echo -e "  ${GREEN}${BOLD}Installation complete.${RESET}"
else
    echo -e "  ${YELLOW}${BOLD}Installed with $ISSUES item(s) needing attention above.${RESET}"
fi

echo ""
echo "  Creating your shortcut…"
echo ""

# Ask for a name via native macOS dialog
APP_NAME=$(osascript \
    -e 'try' \
    -e 'set r to display dialog "What would you like to call the shortcut?" default answer "Mise" buttons {"Skip", "Create Shortcut"} default button "Create Shortcut" with title "Mise"' \
    -e 'if button returned of r is "Skip" then return ""' \
    -e 'return text returned of r' \
    -e 'on error' \
    -e 'return ""' \
    -e 'end try' 2>/dev/null)

if [[ -z "$APP_NAME" ]]; then
    echo "  Skipped. You can launch any time with:  mise"
else
    # Ask where to save it
    LOCATION_BTN=$(osascript \
        -e 'try' \
        -e 'return button returned of (display dialog "Where would you like to save \"'"$APP_NAME"'\"?" buttons {"Desktop", "Applications", "Documents"} default button "Desktop" with title "Mise")' \
        -e 'on error' \
        -e 'return ""' \
        -e 'end try' 2>/dev/null)

    case "$LOCATION_BTN" in
        "Desktop")      SAVE_DIR="$HOME/Desktop" ;;
        "Applications") SAVE_DIR="/Applications" ;;
        "Documents")    SAVE_DIR="$HOME/Documents" ;;
        *)              SAVE_DIR="" ;;
    esac

    if [[ -z "$SAVE_DIR" ]]; then
        echo "  Skipped. You can launch any time with:  mise"
    else
        APP_PATH="${SAVE_DIR%/}/${APP_NAME}.app"

        # Build a minimal .app bundle
        mkdir -p "$APP_PATH/Contents/MacOS"

        # Launcher script
        cat > "$APP_PATH/Contents/MacOS/launcher" << 'LAUNCHER'
#!/bin/bash
exec "$HOME/bin/menu_build_gui"
LAUNCHER
        chmod +x "$APP_PATH/Contents/MacOS/launcher"

        # Info.plist
        cat > "$APP_PATH/Contents/Info.plist" << PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>  <string>launcher</string>
    <key>CFBundleIdentifier</key>  <string>com.square.menu-build</string>
    <key>CFBundleName</key>        <string>${APP_NAME}</string>
    <key>CFBundlePackageType</key> <string>APPL</string>
    <key>CFBundleVersion</key>     <string>1.0</string>
    <key>LSUIElement</key>         <false/>
</dict>
</plist>
PLIST

        ok "Shortcut created: ${APP_PATH}"

        # Offer to reveal it in Finder
        osascript 2>/dev/null << ASEOF || true
tell application "Finder"
    reveal POSIX file "${APP_PATH}"
    activate
end tell
ASEOF
    fi
fi

echo ""
pause "close"
